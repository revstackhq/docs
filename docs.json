{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Revstack",
  "theme": "mint",
  "favicon": "/logo/logo.png",
  "colors": {
    "primary": "#ff592c",
    "dark": "#ff592c",
    "light": "#ff592c"
  },
  "logo": {
    "dark": "/logo/logo.png",
    "light": "/logo/logo.png"
  },
  "api": {
    "openapi": "openapi.json"
  },
  "description": "Open Source Billing OS for Developers. The scalable, developer-first billing engine with subscriptions, invoicing, usage metering, and entitlements.",
  "fonts": {
    "body": {
      "family": "Geist",
      "format": "woff2",
      "weight": 400
    },
    "heading": {
      "family": "Geist",
      "format": "woff2",
      "weight": 600
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "codeblocks": "dark"
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/guides"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "guides/introduction",
              "guides/quickstart",
              "guides/cli",
              "guides/billing-as-code"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "guides/pricing-models",
              "guides/plans",
              "guides/prices",
              "guides/entitlements"
            ]
          },
          {
            "group": "Monetization & UX",
            "pages": [
              "guides/metering",
              "guides/checkout",
              "guides/customer-portal",
              "guides/paywall"
            ]
          },
          {
            "group": "Security & Identity",
            "pages": ["guides/authentication"]
          },
          {
            "group": "Integrations",
            "pages": ["guides/providers/stripe", "guides/providers/polar"]
          },
          {
            "group": "SDKs & Clients",
            "pages": [
              "guides/sdks/react",
              "guides/sdks/vanilla-js",
              "guides/sdks/node",
              "guides/sdks/nextjs",
              "guides/sdks/vercel-ai-wrapper"
            ]
          },
          {
            "group": "Deployment",
            "pages": ["guides/deployment/self-hosted"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication",
              "api-reference/errors"
            ]
          }
        ]
      }
    ]
  }
}
